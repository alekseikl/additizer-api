HTTP_ADDR=:8080

# Database credentials (also consumed by docker-compose).
DB_HOST=localhost
DB_PORT=5432
DB_USER=additizer
DB_PASSWORD=addpwd
DB_NAME=additizer
DB_SSLMODE=disable

# Full DSN used by the app. Keep in sync with the DB_* values above.
DATABASE_URL=host=localhost port=5432 user=additizer password=addpwd dbname=additizer sslmode=disable

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRATION_HOURS=24
BCRYPT_COST=12
